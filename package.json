{
  "name": "Pencil",
  "version": "3.1.1",
  "author": {
    "name": "Evolus",
    "url": "http://evolus.vn"
  },
  "description": "An open-source GUI prototyping tool that is available for ALL platforms.",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "rimraf": "^6.1.3"
  },
  "build": {
    "appId": "vn.evolus.pencil",
    "productName": "Pencil",
    "directories": {
        "output": "dist",
        "app": "app"
    },
    "files": [
        "**/*"
    ],
    "extraMetadata": {
        "main": "index.js"
    },
    "copyright": "Copyright © 2008-2016 Evolus. All rights reserved.",
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 356,
          "y": 140,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 145,
          "type": "file"
        }
      ]
    },
    "linux": {
      "description": "An open-source GUI prototyping tool that is available for ALL platforms.",
      "synopsis": "An open-source GUI prototyping tool that is available for ALL platforms.",
      "maintainer": "Nguyen Tien Dzung <ngtdungnt@gmail.com>",
      "vendor": "Evolus",
      "target": [
        "deb",
        "rpm",
        "tar.gz"
      ],
      "category": "Graphics",
      "packageCategory": "graphics"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "electronDownload": {
      "cache": ".electron-cache"
    },
    "fileAssociations": {
      "ext": [
        "ep",
        "epz",
        "epgz"
      ],
      "name": "Pencil Document"
    }
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "start": "electron ./app --no-sandbox",
    "start:dev": "electron ./app --no-sandbox --enable-dev",
    "clean": "rimraf dist",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux --x64",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:win32": "electron-builder --win --x64",
    "dist:osx": "electron-builder --mac"
  },
  "private": true,
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@mdi/font": "^7.4.47",
    "jimp": "^0.22.12",
    "less": "^4.6.3",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "perfect-freehand": "^1.2.3",
    "q": "^2.0.3",
    "tmp": "^0.2.5"
  }
}
