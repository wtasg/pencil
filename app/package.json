{
  "private": "true",
  "name": "Pencil",
  "productName": "Pencil",
  "description": "An open-source GUI prototyping tool that is available for ALL platforms.",
  "version": "3.1.1",
  "license": "GPL2",
  "main": "index.js",
  "js-flags": "--expose-gc",
  "window": {
    "toolbar": false,
    "position": "center",
    "width": 900,
    "height": 900
  },
  "keywords": [
    "electron",
    "pencil",
    "ui",
    "prototyping",
    "mockup",
    "design",
    "evolus",
    "drawing"
  ],
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "electron-log": "^5.4.3",
    "less": "~4.6.3",
    "lodash": "^4.17.23",
    "md5": "^2.3.0",
    "moment": "^2.30.1",
    "nugget": "^2.2.0",
    "perfect-freehand": "^1.2.3",
    "tmp": "^0.2.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3"
  },
  "scripts": {
    "postinstall": "install-app-deps",
    "install-app-deps": "node ./node_modules/electron-builder/out/install-app-deps.js",
    "start": "./node_modules/.bin/electron .",
    "start:dev": "./node_modules/.bin/electron . --enable-dev --enable-transparent-visuals",
    "start:mac": "./node_modules/.bin/electron . --enable-dev",
    "clean": "rm -rf dist",
    "build": "./node_modules/.bin/electron-builder",
    "pack": "./node_modules/.bin/electron-builder",
    "dist": "./node_modules/.bin/electron-builder",
    "release": "./node_modules/.bin/electron-builder",
    "dist:linux": "./node_modules/.bin/electron-builder --linux --ia32 --x64",
    "dist:win32": "./node_modules/.bin/electron-builder --windows --ia32 --x64",
    "dist:osx": "./node_modules/.bin/electron-builder --macos"
  }
}