{
  "private": "true",
  "name": "Pencil",
  "productName": "Pencil",
  "description": "An open-source GUI prototyping tool that is available for ALL platforms.",
  "version": "3.1.1",
  "license": "GPL2",
  "main": "index.js",
  "js-flags": "--expose-gc",
  "window": {
    "toolbar": false,
    "position": "center",
    "width": 900,
    "height": 900
  },
  "keywords": [
    "electron",
    "pencil",
    "ui",
    "prototyping",
    "mockup",
    "design",
    "evolus",
    "drawing"
  ],
  "dependencies": {
    "@codemirror/commands": "6.10.3",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/lang-xml": "6.1.0",
    "@codemirror/language": "6.12.2",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.40.0",
    "@electron/remote": "^2.1.3",
    "@mdi/font": "7.4.47",
    "@wtasnorg/ui": "^0.0.1",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "bootstrap": "5.3.8",
    "codemirror": "6.0.2",
    "electron-log": "^5.4.3",
    "font-awesome": "4.7.0",
    "less": "~4.6.3",
    "lodash": "^4.17.23",
    "md5": "^2.3.0",
    "moment": "^2.30.1",
    "nugget": "^2.2.0",
    "perfect-freehand": "^1.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tmp": "^0.2.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3"
  },
  "scripts": {
    "postinstall": "install-app-deps && npm run react-ui:manifest",
    "install-app-deps": "node ./node_modules/electron-builder/out/install-app-deps.js",
    "react-ui:manifest": "node ./scripts/generate-react-ui-manifest.js",
    "libs:sync": "node ./scripts/sync-vendor-libs.js",
    "start": "./node_modules/.bin/electron .",
    "start:dev": "./node_modules/.bin/electron . --enable-dev --enable-transparent-visuals",
    "start:mac": "./node_modules/.bin/electron . --enable-dev",
    "clean": "rm -rf dist",
    "build": "npm run libs:sync && ./node_modules/.bin/electron-builder",
    "pack": "npm run libs:sync && ./node_modules/.bin/electron-builder",
    "dist": "npm run libs:sync && ./node_modules/.bin/electron-builder",
    "release": "npm run libs:sync && ./node_modules/.bin/electron-builder",
    "dist:linux": "npm run libs:sync && ./node_modules/.bin/electron-builder --linux --ia32 --x64",
    "dist:win32": "npm run libs:sync && ./node_modules/.bin/electron-builder --windows --ia32 --x64",
    "dist:osx": "npm run libs:sync && ./node_modules/.bin/electron-builder --macos"
  }
}